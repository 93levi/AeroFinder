# --- Backend environment variables ---
# Copy this file to .env and fill in real values. Never commit .env.

# Secret used to sign JWTs. Use a long random string.
JWT_SECRET=replace-with-a-long-random-string

# Managed MySQL connection (e.g. Aiven free tier).
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=rentals

# Set to "true" for managed cloud MySQL (they require TLS).
DB_SSL=true

# Optional: restrict CORS to your frontend origin (defaults to *).
# CORS_ORIGIN=https://aero-finder-rho.vercel.app

# PORT is provided automatically by Render; defaults to 3000 locally.
# PORT=3000
